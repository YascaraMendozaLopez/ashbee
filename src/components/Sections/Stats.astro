---
const stats = [
  { value: '5k+', label: 'Clientas Felices' },
  { value: '15+', label: 'Especialidades' },
  { value: '10+', label: 'Años de Experiencia' },
  { value: '100%', label: 'Tecnología Certificada' },
];
---
<section class="py-16 bg-ashbee-accent text-white">
  <div class="max-w-7xl mx-auto px-6">
    <div class="grid grid-cols-2 lg:grid-cols-4 gap-12 text-center">
      {stats.map(stat => (
        <div class="space-y-2">
          <div class="font-serif text-4xl md:text-5xl text-ashbee-primary">{stat.value}</div>
          <div class="text-xs uppercase tracking-[0.2em] font-light text-ashbee-secondary/70">{stat.label}</div>
        </div>
      ))}
    </div>
  </div>
</section>
