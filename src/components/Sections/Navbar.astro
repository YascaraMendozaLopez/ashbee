---
const navLinks = [
  { name: 'Inicio', href: '#' },
  { name: 'Nosotros', href: '#nosotros' },
  { name: 'Servicios', href: '#servicios' },
  { name: 'Packs', href: '#packs' },
  { name: 'Contacto', href: '#contacto' },
];
---
<nav id="navbar" class="fixed w-full z-50 transition-all duration-500 px-6 py-4">
  <div class="max-w-7xl mx-auto flex justify-between items-center">
    <a href="#" class="font-serif text-2xl tracking-widest text-white drop-shadow-md transition-colors" id="nav-logo">
      ASHBEE
    </a>
    
    <div class="hidden md:flex gap-8">
      {navLinks.map(link => (
        <a href={link.href} class="text-sm uppercase tracking-widest text-white hover:text-ashbee-primary transition-colors font-medium">
          {link.name}
        </a>
      ))}
    </div>

    <button class="md:hidden text-white" id="menu-toggle">
      <svg class="w-6 h-6" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path d="M4 6h16M4 12h16m-7 6h7"></path></svg>
    </button>
  </div>
</nav>

<script>
  const nav = document.getElementById('navbar');
  const logo = document.getElementById('nav-logo');
  const links = nav?.querySelectorAll('a');

  window.addEventListener('scroll', () => {
    if (window.scrollY > 50) {
      nav?.classList.add('bg-white', 'shadow-md', 'py-3');
      nav?.classList.remove('py-4');
      logo?.classList.add('text-ashbee-dark');
      logo?.classList.remove('text-white');
      links?.forEach(l => l.classList.replace('text-white', 'text-ashbee-dark'));
    } else {
      nav?.classList.remove('bg-white', 'shadow-md', 'py-3');
      nav?.classList.add('py-4');
      logo?.classList.replace('text-ashbee-dark', 'text-white');
      links?.forEach(l => l.classList.replace('text-ashbee-dark', 'text-white'));
    }
  });
</script>
