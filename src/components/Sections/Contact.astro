---
const WHATSAPP_NUMBER = "591XXXXXXX"; 
const MESSAGE = "Hola ASHBEE, me gustaría recibir información sobre sus servicios.";
const waLink = `https://wa.me/${WHATSAPP_NUMBER}?text=${encodeURIComponent(MESSAGE)}`;
---
<section id="contacto" class="py-24 bg-ashbee-dark text-white px-6">
  <div class="max-w-4xl mx-auto text-center">
    
    <span class="text-ashbee-primary uppercase tracking-[0.4em] text-sm font-bold block mb-4 animate-pulse">
      Atención Personalizada
    </span>
    
    <h2 class="font-serif text-4xl md:text-6xl mb-8 text-white leading-tight">
      ¿Lista para tu momento de bienestar?
    </h2>
    
    <p class="text-gray-300 mb-12 text-lg font-light leading-relaxed max-w-2xl mx-auto">
      Haz clic en el botón de abajo para chatear directamente con nosotros por WhatsApp. 
      Te asesoraremos sobre el tratamiento ideal para ti en Santa Cruz.
    </p>

<a 
  href={waLink} 
  target="_blank" 
  rel="noopener noreferrer"
  class="inline-flex items-center gap-6 px-6 py-4 bg-ashbee-primary text-ashbee-dark hover:bg-white transition-all duration-300 rounded-full font-semibold text-xs md:text-sm uppercase tracking-[0.3em] shadow-[0_0_30px_rgba(191,163,126,0.4)] hover:shadow-[0_0_40px_rgba(191,163,126,0.6)] group"
>
  <svg class="size-8 fill-ashbee-dark group-hover:scale-110 group-hover:rotate-6 transition-all duration-300" fill="none"><path fill="#1a1a1a" d="M9.2 27.467c2 1.2 4.4 1.866 6.8 1.866 7.333 0 13.333-6 13.333-13.333S23.333 2.667 16 2.667 2.667 8.667 2.667 16c0 2.4.666 4.666 1.733 6.666l-1.733 6.667z"/><path fill="#bfa37e" d="M22 19.798c0 .216-.048.438-.15.654s-.235.42-.409.612a2.7 2.7 0 0 1-.985.708q-.54.227-1.172.228-.921.002-1.959-.438a10.6 10.6 0 0 1-2.067-1.188 17 17 0 0 1-1.971-1.68 17 17 0 0 1-1.677-1.962 10.7 10.7 0 0 1-1.177-2.046Q10 13.66 10 12.724a3.1 3.1 0 0 1 .216-1.158q.216-.55.691-1.002c.385-.378.806-.564 1.25-.564.168 0 .337.036.487.108a1 1 0 0 1 .403.336l1.394 1.962q.16.224.24.42a.95.95 0 0 1 .084.366.8.8 0 0 1-.126.426 2 2 0 0 1-.336.426l-.457.474a.32.32 0 0 0-.096.24c0 .048.006.09.018.138.018.048.036.084.048.12q.162.299.559.768.403.47.87.948c.325.318.638.612.956.882.313.264.571.444.776.552q.045.02.108.048a.4.4 0 0 0 .15.024.33.33 0 0 0 .246-.102l.457-.45q.225-.226.433-.336a.8.8 0 0 1 .426-.126 1 1 0 0 1 .367.078q.197.081.42.234l1.99 1.41a.9.9 0 0 1 .33.384c.06.15.096.3.096.468"/></svg>
  HABLAR POR WHATSAPP
</a>

    <div class="mt-20 grid grid-cols-1 md:grid-cols-3 gap-12 text-sm tracking-[0.2em] border-t border-white/10 pt-12">
      <div class="flex flex-col items-center gap-3">
        <span class="text-ashbee-primary font-bold uppercase">Ubicación</span>
        <span class="text-white/80 font-sans">Santa Cruz, Bolivia</span>
      </div>
      <div class="flex flex-col items-center gap-3">
        <span class="text-ashbee-primary font-bold uppercase">Horarios</span>
        <span class="text-white/80 font-sans">Lun - Sáb: 9:00 - 19:00</span>
      </div>
      <div class="flex flex-col items-center gap-3">
        <span class="text-ashbee-primary font-bold uppercase">Síguenos</span>
        <span class="text-white/80 font-sans">@ashbee.spa</span>
      </div>
    </div>
  </div>
</section>
