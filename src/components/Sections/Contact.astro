---
const WHATSAPP_NUMBER = "591XXXXXXX"; 
const MESSAGE = "Hola ASHBEE, me gustaría recibir información sobre sus servicios.";
const waLink = `https://wa.me/${WHATSAPP_NUMBER}?text=${encodeURIComponent(MESSAGE)}`;
---
<section id="contacto" class="py-24 bg-ashbee-dark text-white px-6">
  <div class="max-w-4xl mx-auto text-center">
    
    <span class="text-ashbee-primary uppercase tracking-[0.4em] text-sm font-bold block mb-4 animate-pulse">
      Atención Personalizada
    </span>
    
    <h2 class="font-serif text-4xl md:text-6xl mb-8 text-white leading-tight">
      ¿Lista para tu momento de bienestar?
    </h2>
    
    <p class="text-gray-300 mb-12 text-lg font-light leading-relaxed max-w-2xl mx-auto">
      Haz clic en el botón de abajo para chatear directamente con nosotros por WhatsApp. 
      Te asesoraremos sobre el tratamiento ideal para ti en Santa Cruz.
    </p>

<a 
  href={waLink} 
  target="_blank" 
  rel="noopener noreferrer"
  class="inline-flex items-center gap-6 px-14 py-6 bg-ashbee-primary text-ashbee-dark hover:bg-white transition-all duration-300 rounded-full font-semibold text-xs md:text-sm uppercase tracking-[0.3em] shadow-[0_0_30px_rgba(191,163,126,0.4)] hover:shadow-[0_0_40px_rgba(191,163,126,0.6)] group"
>
  <svg class="w-12 h-12 md:w-14 md:h-14 fill-ashbee-dark group-hover:scale-110 group-hover:rotate-6 transition-all duration-300" viewBox="0 0 24 24">
    <path d="M12.031 6.172c-3.181 0-5.767 2.586-5.768 5.766-.001 1.298.38 2.27 1.019 3.287l-.539 2.016 2.041-.54c.953.523 1.929.901 3.247.901 3.181 0 5.768-2.587 5.768-5.766 0-3.181-2.587-5.764-5.768-5.764zm3.371 8.203c-.144.405-.833.722-1.148.773-.314.051-.617.062-1.815-.353-1.391-.482-2.315-1.802-2.385-1.895-.07-.093-.561-.746-.561-1.422 0-.675.353-.984.479-1.112.126-.127.275-.158.367-.158h.262c.084 0 .197.003.284.209.102.245.349.851.379.912.031.062.051.135.01.217-.04.082-.061.134-.122.205-.061.071-.128.158-.184.211-.062.062-.127.13-.054.256.074.125.327.54.701.874.481.43.885.563 1.011.626.126.062.201.051.275-.035.074-.086.317-.371.401-.497.086-.127.171-.107.288-.061.117.046.744.351.872.417.127.066.212.097.243.148.03.051.03.296-.114.701z"></path>
  </svg>
  HABLAR POR WHATSAPP
</a>

    <div class="mt-20 grid grid-cols-1 md:grid-cols-3 gap-12 text-sm tracking-[0.2em] border-t border-white/10 pt-12">
      <div class="flex flex-col items-center gap-3">
        <span class="text-ashbee-primary font-bold uppercase">Ubicación</span>
        <span class="text-white/80 font-sans">Santa Cruz, Bolivia</span>
      </div>
      <div class="flex flex-col items-center gap-3">
        <span class="text-ashbee-primary font-bold uppercase">Horarios</span>
        <span class="text-white/80 font-sans">Lun - Sáb: 9:00 - 19:00</span>
      </div>
      <div class="flex flex-col items-center gap-3">
        <span class="text-ashbee-primary font-bold uppercase">Síguenos</span>
        <span class="text-white/80 font-sans">@ashbee.spa</span>
      </div>
    </div>
  </div>
</section>
